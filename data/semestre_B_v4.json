{
  "meta": {
    "version": 4,
    "nombre": "Plantilla Semestre B v4 (sin numeros magicos)",
    "periodo": "par",
    "fuente": "semestre_B.json + HorarioBaseB.txt",
    "notas": [
      "IDs de profesores se normalizaron a t###; el id anterior queda en profesores[].legacy.id.",
      "academiaId ahora es slug (ej. 'computacion') en lugar de indices numericos.",
      "turno del profesor ahora es explicito ('matutino'|'vespertino').",
      "groupSpecs se conserva como legacy porque usa indices del TXT (lista de 45) que no coincide 1:1 con asignaturas actuales.",
      "asignaturas: horasPorSemana renombrado a sesionesPorSemana (sesiones/semana).",
      "asignaturas: tipoHoraEstudio se expresa como estudio.mode (string) y se conserva legacy.tipoHoraEstudio.",
      "grupos: planAsignaturas se infiere desde legacyGroupSpecs usando indices del TXT y se expresa con ids de asignatura (strings).",
      "asignaturas: se agregan Optativa 1 y Optativa 2 si faltaban."
    ]
  },
